{
  "$schema": "./secrets-manifest.schema.json",
  "vault_mount": "secret",
  "vault_base_path": "oms",
  "bitwarden_collection": "OMS - Open Medical Skills",
  "secrets": [
    {
      "env_var": "GITHUB_PAT",
      "vault_path": "github/pat",
      "bw_name": "OMS | GitHub | PAT",
      "description": "GitHub Personal Access Token for API operations",
      "required": true,
      "rotate_days": 90
    },
    {
      "env_var": "GITHUB_CLIENT_ID",
      "vault_path": "github/client-id",
      "bw_name": "OMS | GitHub | OAuth Client ID",
      "description": "GitHub OAuth App client ID",
      "required": true
    },
    {
      "env_var": "GITHUB_CLIENT_SECRET",
      "vault_path": "github/client-secret",
      "bw_name": "OMS | GitHub | OAuth Client Secret",
      "description": "GitHub OAuth App client secret",
      "required": true,
      "rotate_days": 180
    },
    {
      "env_var": "CF_API_TOKEN",
      "vault_path": "cloudflare/api-token",
      "bw_name": "OMS | Cloudflare | API Token",
      "description": "Cloudflare API token for Workers/Pages deployment",
      "required": true,
      "rotate_days": 365
    },
    {
      "env_var": "CF_ACCOUNT_ID",
      "vault_path": "cloudflare/account-id",
      "bw_name": "OMS | Cloudflare | Account ID",
      "description": "Cloudflare account identifier",
      "required": true
    },
    {
      "env_var": "DB_USER",
      "vault_path": "database/postgres",
      "vault_key": "username",
      "bw_name": "OMS | Database | PostgreSQL",
      "bw_field": "username",
      "description": "PostgreSQL database username",
      "required": true
    },
    {
      "env_var": "DB_PASSWORD",
      "vault_path": "database/postgres",
      "vault_key": "password",
      "bw_name": "OMS | Database | PostgreSQL",
      "bw_field": "password",
      "description": "PostgreSQL database password",
      "required": true,
      "rotate_days": 90
    },
    {
      "env_var": "DB_NAME",
      "vault_path": "database/postgres",
      "vault_key": "database",
      "bw_name": "OMS | Database | PostgreSQL",
      "bw_field": "database",
      "description": "PostgreSQL database name",
      "required": true
    },
    {
      "env_var": "DB_HOST",
      "vault_path": "database/postgres",
      "vault_key": "host",
      "bw_name": "OMS | Database | PostgreSQL",
      "bw_field": "host",
      "description": "PostgreSQL host address",
      "required": true
    },
    {
      "env_var": "DB_PORT",
      "vault_path": "database/postgres",
      "vault_key": "port",
      "bw_name": "OMS | Database | PostgreSQL",
      "bw_field": "port",
      "description": "PostgreSQL port",
      "required": true
    },
    {
      "env_var": "OAUTH_REDIRECT_URI",
      "vault_path": "oauth/redirect-uri",
      "bw_name": "OMS | OAuth | Redirect URI",
      "description": "OAuth callback URL",
      "required": true
    },
    {
      "env_var": "OPENFDA_API_KEY",
      "vault_path": "api-keys/openfda",
      "bw_name": "OMS | API Keys | OpenFDA",
      "description": "OpenFDA API key (optional, increases rate limits)",
      "required": false
    },
    {
      "env_var": "NCBI_API_KEY",
      "vault_path": "api-keys/ncbi",
      "bw_name": "OMS | API Keys | NCBI",
      "description": "NCBI/PubMed API key",
      "required": false
    },
    {
      "env_var": "ALLOWED_ORIGIN",
      "vault_path": "site/allowed-origin",
      "bw_name": "OMS | Site | Allowed Origin",
      "description": "CORS allowed origin for API",
      "required": true
    },
    {
      "env_var": "API_BASE_URL",
      "vault_path": "site/api-base-url",
      "bw_name": "OMS | Site | API Base URL",
      "description": "Base URL for the submission API",
      "required": true
    }
  ]
}
