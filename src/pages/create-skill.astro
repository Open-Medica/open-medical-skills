---
import "../styles/global.css";
import Header from "../components/Header.astro";
import SkillCreatorApp from "../features/skill-creator/components/SkillCreatorApp";

const title = "Create a Skill";
const description = "Build a medical AI skill with guided AI assistance. Write section by section, refine with LLM, and export as SKILL.md and content YAML.";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | Open Medical Skills`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Open Medical Skills" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        if (stored === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-gray-950 text-slate-100 antialiased">
    <Header />
    <SkillCreatorApp client:only="react" />
  </body>
</html>
