---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Verify Magic Link" description="Verifying your magic link sign-in.">
  <meta slot="head" name="referrer" content="no-referrer" />
  <div class="flex min-h-[calc(100vh-200px)] items-center justify-center px-4 py-12">
    <div class="w-full max-w-sm text-center">
      <!-- Loading state -->
      <div id="verify-loading">
        <div class="mx-auto mb-6 h-10 w-10 animate-spin rounded-full border-4 border-slate-700 border-t-primary-light"></div>
        <h1 class="text-xl font-semibold text-white">Verifying your link...</h1>
        <p class="mt-2 text-sm text-slate-400">Please wait while we sign you in.</p>
      </div>

      <!-- Success state -->
      <div id="verify-success" class="hidden">
        <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-green-900/30">
          <svg class="h-7 w-7 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h1 class="text-xl font-semibold text-white">Signed in successfully!</h1>
        <p class="mt-2 text-sm text-slate-400">Redirecting you now...</p>
      </div>

      <!-- Error state -->
      <div id="verify-error" class="hidden">
        <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-red-900/30">
          <svg class="h-7 w-7 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M6 18L18 6M6 6l12 12" />
          </svg>
        </div>
        <h1 class="text-xl font-semibold text-white">Verification failed</h1>
        <p id="verify-error-message" class="mt-2 text-sm text-red-400"></p>
        <div class="mt-6 flex flex-col gap-3">
          <a
            href="/auth/signin"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-cyan-500 to-teal-500 px-4 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-90"
          >
            Try again
          </a>
          <a href="/" class="text-sm text-slate-500 hover:text-slate-300 transition-colors">
            Return home
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || '/api';

  async function verifyToken() {
    const loadingEl = document.getElementById("verify-loading");
    const successEl = document.getElementById("verify-success");
    const errorEl = document.getElementById("verify-error");
    const errorMsgEl = document.getElementById("verify-error-message");

    function showError(msg: string) {
      loadingEl?.classList.add("hidden");
      errorEl?.classList.remove("hidden");
      if (errorMsgEl) errorMsgEl.textContent = msg;
    }

    function showSuccess() {
      loadingEl?.classList.add("hidden");
      successEl?.classList.remove("hidden");
    }

    try {
      const params = new URLSearchParams(window.location.search);
      const token = params.get("token");

      if (!token) {
        showError("No verification token found. The link may be invalid or expired.");
        return;
      }

      const res = await fetch(`${API_URL}/auth/verify?token=${encodeURIComponent(token)}`, {
        credentials: "include",
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        showError((data as Record<string, string>).error || "The magic link is invalid or has expired. Please request a new one.");
        return;
      }

      showSuccess();
      setTimeout(() => {
        window.location.href = "/";
      }, 1200);
    } catch {
      showError("An unexpected error occurred. Please try again.");
    }
  }

  verifyToken();
</script>
