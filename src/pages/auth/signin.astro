---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Sign In" description="Sign in to OpenMedica to save skills and personalize your experience.">
  <div class="flex min-h-[calc(100vh-200px)] items-center justify-center px-4 py-12">
    <div class="w-full max-w-sm">
      <!-- Logo -->
      <div class="mb-8 text-center">
        <a href="/" class="inline-flex flex-col items-center">
          <span class="text-2xl font-light tracking-tight text-white">
            Open<span class="font-bold bg-gradient-to-r from-cyan-400 to-teal-400 bg-clip-text text-transparent">Medica</span>
          </span>
        </a>
        <h1 class="mt-4 text-xl font-semibold text-white">Sign in or create an account</h1>
        <p class="mt-1.5 text-sm text-slate-400">
          Save skills, track your favorites, and personalize your experience. No account yet? Signing in creates one automatically.
        </p>
      </div>

      <!-- Sign-in card -->
      <div class="rounded-xl border border-slate-800 bg-slate-900 p-6 shadow-xl">
        <!-- GitHub -->
        <a
          id="github-btn"
          href="#"
          class="flex w-full items-center justify-center gap-3 rounded-lg border border-slate-700 bg-slate-800 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-slate-700 hover:border-slate-600"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          Continue with GitHub
        </a>

        <!-- Google -->
        <a
          id="google-btn"
          href="#"
          class="mt-3 flex w-full items-center justify-center gap-3 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 dark:border-slate-600 dark:bg-slate-100 dark:text-slate-800 dark:hover:bg-white"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        </a>

        <!-- Divider -->
        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-slate-700"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="bg-slate-900 px-3 text-slate-500">or</span>
          </div>
        </div>

        <!-- Email magic link form -->
        <form id="magic-link-form" class="space-y-3">
          <div>
            <label for="email" class="sr-only">Email address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@example.com"
              class="w-full rounded-lg border border-slate-700 bg-slate-800 px-4 py-2.5 text-sm text-white placeholder-slate-500 transition-colors focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
            />
          </div>
          <button
            type="submit"
            id="magic-link-btn"
            class="flex w-full items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-cyan-500 to-teal-500 px-4 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-90 disabled:opacity-50 disabled:cursor-wait"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Send Magic Link
          </button>
          <p id="magic-link-error" class="hidden text-center text-xs text-red-400"></p>
        </form>
      </div>

      <!-- Footer -->
      <p class="mt-6 text-center text-xs text-slate-500">
        By signing in, you agree to our
        <a href="/terms" class="text-primary hover:text-primary-light">Terms of Use</a>
        and
        <a href="/privacy" class="text-primary hover:text-primary-light">Privacy Policy</a>.
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  import { getGitHubAuthUrl, getGoogleAuthUrl, sendMagicLink } from "../../lib/auth";

  // Wire up OAuth buttons
  const githubBtn = document.getElementById("github-btn") as HTMLAnchorElement;
  const googleBtn = document.getElementById("google-btn") as HTMLAnchorElement;

  if (githubBtn) githubBtn.href = getGitHubAuthUrl();
  if (googleBtn) googleBtn.href = getGoogleAuthUrl();

  // Wire up magic link form
  const form = document.getElementById("magic-link-form") as HTMLFormElement;
  const emailInput = document.getElementById("email") as HTMLInputElement;
  const submitBtn = document.getElementById("magic-link-btn") as HTMLButtonElement;
  const errorEl = document.getElementById("magic-link-error") as HTMLParagraphElement;

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      if (!email) return;

      submitBtn.disabled = true;
      errorEl.classList.add("hidden");

      const ok = await sendMagicLink(email);

      if (ok) {
        window.location.href = `/auth/magic-link-sent?email=${encodeURIComponent(email)}`;
      } else {
        errorEl.textContent = "Failed to send magic link. Please try again.";
        errorEl.classList.remove("hidden");
        submitBtn.disabled = false;
      }
    });
  }
</script>
