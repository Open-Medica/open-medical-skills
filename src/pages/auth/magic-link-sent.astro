---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Check Your Email" description="A magic link has been sent to your email address.">
  <div class="flex min-h-[calc(100vh-200px)] items-center justify-center px-4 py-12">
    <div class="w-full max-w-sm text-center">
      <!-- Email icon -->
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-cyan-500/10 ring-1 ring-cyan-500/20">
        <svg class="h-8 w-8 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
      </div>

      <h1 class="text-xl font-semibold text-white">Check your email!</h1>

      <p class="mt-3 text-sm text-slate-400">
        We sent a magic link to
        <span id="email-display" class="font-medium text-primary-light"></span>.
        Click the link in the email to sign in.
      </p>

      <div class="mt-6 rounded-lg border border-slate-800 bg-slate-900/50 p-4">
        <p class="text-xs text-slate-500">
          The link will expire in 15 minutes. If you don't see the email, check your spam folder.
        </p>
      </div>

      <div class="mt-8 flex flex-col gap-3">
        <a
          href="/auth/signin"
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-4 py-2.5 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-700"
        >
          Try a different sign-in method
        </a>
        <a
          href="/"
          class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
        >
          Return home
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const emailEl = document.getElementById("email-display");
  if (emailEl) {
    const params = new URLSearchParams(window.location.search);
    const email = params.get("email");
    emailEl.textContent = email || "your email";
  }
</script>
