---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  {
    title: "Drug Shortage Tracker",
    description: "Search and track FDA drug recalls, enforcement actions, and shortage events in real-time. Filter by status, classification, and manufacturer.",
    href: "/fda-tools/drug-shortages",
    status: "live" as const,
    statusLabel: "Live",
    color: "cyan",
  },
  {
    title: "Drug Adverse Events",
    description: "Search FDA Adverse Event Reporting System (FAERS) for drug safety signals, side effect reports, and medication error data.",
    href: "#",
    status: "coming-soon" as const,
    statusLabel: "Coming Soon",
    color: "amber",
  },
  {
    title: "Drug Labeling Search",
    description: "Search FDA-approved drug labels, prescribing information, medication guides, and boxed warnings.",
    href: "#",
    status: "coming-soon" as const,
    statusLabel: "Coming Soon",
    color: "purple",
  },
  {
    title: "Medical Device Recalls",
    description: "Track Class I, II, and III medical device recalls, safety alerts, and correction notices from the FDA.",
    href: "#",
    status: "coming-soon" as const,
    statusLabel: "Coming Soon",
    color: "rose",
  },
  {
    title: "Drug Interactions Checker",
    description: "Check potential drug-drug interactions using FDA labeling data and adverse event co-occurrence patterns.",
    href: "#",
    status: "coming-soon" as const,
    statusLabel: "Coming Soon",
    color: "emerald",
  },
  {
    title: "NDC Directory",
    description: "Look up National Drug Code (NDC) numbers, manufacturers, active ingredients, routes, and packaging.",
    href: "#",
    status: "coming-soon" as const,
    statusLabel: "Coming Soon",
    color: "blue",
  },
];

const liveCount = tools.filter(t => t.status === "live").length;
const totalCount = tools.length;

const iconMap: Record<string, string> = {
  "Drug Shortage Tracker": `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 00.659 1.591L19 14.5M14.25 3.104c.251.023.501.05.75.082M19 14.5l-1.478 6.324a1.5 1.5 0 01-1.464 1.176H7.942a1.5 1.5 0 01-1.464-1.176L5 14.5m14 0H5" />`,
  "Drug Adverse Events": `<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />`,
  "Drug Labeling Search": `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9zm3.75 11.625a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />`,
  "Medical Device Recalls": `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.384 3.115A1.5 1.5 0 014.5 16.92V7.08a1.5 1.5 0 011.536-1.365l5.384 3.115a1.5 1.5 0 010 2.59zm0 0L19.5 12m-8.08 3.17L19.5 12m0 0l-8.08-3.17M19.5 12h0" /><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5V18M15 7.5V18M3 16.811V8.69c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 010 1.954l-7.108 4.061A1.125 1.125 0 013 16.811z" />`,
  "Drug Interactions Checker": `<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />`,
  "NDC Directory": `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5z" />`,
};

const colorMap: Record<string, { bg: string; text: string; border: string; iconBg: string }> = {
  cyan:    { bg: "bg-cyan-500/10",    text: "text-cyan-400",    border: "border-cyan-700/50",    iconBg: "bg-cyan-500/10" },
  amber:   { bg: "bg-amber-500/10",   text: "text-amber-400",   border: "border-amber-700/50",   iconBg: "bg-amber-500/10" },
  purple:  { bg: "bg-purple-500/10",  text: "text-purple-400",  border: "border-purple-700/50",  iconBg: "bg-purple-500/10" },
  rose:    { bg: "bg-rose-500/10",    text: "text-rose-400",    border: "border-rose-700/50",    iconBg: "bg-rose-500/10" },
  emerald: { bg: "bg-emerald-500/10", text: "text-emerald-400", border: "border-emerald-700/50", iconBg: "bg-emerald-500/10" },
  blue:    { bg: "bg-blue-500/10",    text: "text-blue-400",    border: "border-blue-700/50",    iconBg: "bg-blue-500/10" },
};
---

<BaseLayout title="FDA Tools" description="Access real-time FDA data for clinical research. Drug shortages, adverse events, device recalls, and more.">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-slate-800 bg-gradient-to-b from-slate-900 via-orange-950/10 to-gray-950">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(251,146,60,0.08),transparent)]"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:px-8">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-orange-800/40 bg-orange-950/30 px-4 py-1.5 text-xs font-medium text-orange-300">
        <span class="h-1.5 w-1.5 rounded-full bg-orange-400 animate-pulse"></span>
        Data from openFDA API
      </div>

      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
        FDA <span class="bg-gradient-to-r from-orange-400 to-amber-400 bg-clip-text text-transparent">Tools</span>
      </h1>

      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-slate-400">
        Access real-time FDA data for clinical research. Search drug shortages, adverse events, device recalls, and more.
      </p>

      <div class="mt-6 flex flex-wrap items-center justify-center gap-4 text-sm text-slate-500">
        <span>{liveCount} live tool{liveCount !== 1 ? "s" : ""}</span>
        <span class="text-slate-700">&middot;</span>
        <span>{totalCount - liveCount} coming soon</span>
      </div>
    </div>
  </section>

  <!-- Tool Cards -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-6 sm:grid-cols-2">
      {tools.map((tool) => {
        const colors = colorMap[tool.color];
        const icon = iconMap[tool.title];
        const isLive = tool.status === "live";

        return isLive ? (
          <a
            href={tool.href}
            class:list={[
              "group rounded-xl border border-slate-800 bg-slate-900/50 p-6 transition-all",
              `hover:${colors.border} hover:bg-slate-900`,
            ]}
          >
            <div class="flex items-start justify-between">
              <div class="flex items-center gap-3">
                <div class:list={["flex h-10 w-10 items-center justify-center rounded-lg", colors.iconBg, colors.text]}>
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <Fragment set:html={icon} />
                  </svg>
                </div>
                <div>
                  <h3 class:list={["font-semibold text-white transition-colors", `group-hover:${colors.text}`]}>
                    {tool.title}
                  </h3>
                </div>
              </div>
              <span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-800/50 bg-emerald-950/30 px-2.5 py-1 text-[10px] font-medium text-emerald-400">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                {tool.statusLabel}
              </span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">
              {tool.description}
            </p>
            <div class:list={["mt-4 flex items-center gap-1.5 text-xs font-medium", colors.text]}>
              Explore
              <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ) : (
          <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6 opacity-60">
            <div class="flex items-start justify-between">
              <div class="flex items-center gap-3">
                <div class:list={["flex h-10 w-10 items-center justify-center rounded-lg", colors.iconBg, colors.text]}>
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <Fragment set:html={icon} />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-white">{tool.title}</h3>
                </div>
              </div>
              <span class="inline-flex items-center gap-1.5 rounded-full border border-amber-800/50 bg-amber-950/30 px-2.5 py-1 text-[10px] font-medium text-amber-400">
                {tool.statusLabel}
              </span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">
              {tool.description}
            </p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Attribution -->
  <section class="border-t border-slate-800">
    <div class="mx-auto max-w-3xl px-4 py-12 text-center sm:px-6 lg:px-8">
      <p class="text-sm text-slate-500">
        Powered by the <a href="https://open.fda.gov" target="_blank" rel="noopener noreferrer" class="font-medium text-orange-400/70 hover:text-orange-400 transition-colors">openFDA API</a>. Data is provided by the U.S. Food and Drug Administration.
      </p>
      <p class="mt-2 text-xs text-slate-600">
        For research purposes only. Not a substitute for professional medical judgment.
      </p>
    </div>
  </section>
</BaseLayout>
