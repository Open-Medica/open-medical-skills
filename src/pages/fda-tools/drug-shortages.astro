---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FdaToolsApp from '../../features/fda-tools/components/FdaToolsApp';
---

<BaseLayout title="FDA Drug Shortage Tracker" description="Real-time FDA drug shortage and enforcement data for healthcare professionals.">
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/fda-tools" class="hover:text-cyan-400 transition-colors">FDA Tools</a>
      <span class="mx-2">&rarr;</span>
      <span class="text-white">Drug Shortage Tracker</span>
    </nav>

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white">FDA Drug Shortage Tracker</h1>
      <p class="mt-2 text-slate-400">
        Real-time drug enforcement and shortage data from the U.S. Food and Drug Administration.
      </p>
    </div>
    <FdaToolsApp client:load />
  </section>
</BaseLayout>
