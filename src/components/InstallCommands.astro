---
interface Props {
  install?: {
    npx?: string;
    wget?: string;
    git?: string;
    docker?: string;
  };
}

const { install } = Astro.props;

const methods = [
  { key: "npx", label: "npx", command: install?.npx },
  { key: "wget", label: "wget", command: install?.wget },
  { key: "git", label: "git", command: install?.git },
  { key: "docker", label: "docker", command: install?.docker },
].filter((m) => m.command);
---

{methods.length > 0 ? (
  <div class="install-commands">
    <!-- Tabs -->
    <div class="flex border-b border-slate-200 dark:border-slate-700" role="tablist">
      {methods.map((method, i) => (
        <button
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          aria-controls={`panel-${method.key}`}
          data-tab={method.key}
          class:list={[
            "install-tab px-4 py-2 text-sm font-medium transition-colors border-b-2 -mb-px",
            i === 0
              ? "border-primary text-primary dark:text-primary-light"
              : "border-transparent text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300",
          ]}
        >
          {method.label}
        </button>
      ))}
    </div>

    <!-- Panels -->
    {methods.map((method, i) => (
      <div
        id={`panel-${method.key}`}
        role="tabpanel"
        class:list={["install-panel mt-3", i !== 0 && "hidden"]}
        data-panel={method.key}
      >
        <div class="group relative rounded-lg bg-slate-50 dark:bg-slate-800/60">
          <pre class="overflow-x-auto p-4 text-sm"><code class="font-mono text-slate-800 dark:text-slate-200">{method.command}</code></pre>
          <button
            class="copy-btn absolute right-2 top-2 rounded-md bg-white/80 p-1.5 text-slate-400 opacity-0 transition-all hover:text-slate-600 group-hover:opacity-100 dark:bg-slate-700/80 dark:hover:text-slate-200"
            data-command={method.command}
            aria-label={`Copy ${method.label} command`}
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
            </svg>
          </button>
        </div>
      </div>
    ))}
  </div>
) : (
  <p class="text-sm text-slate-500 dark:text-slate-400">No install commands available.</p>
)}

<script>
  document.querySelectorAll(".install-commands").forEach((container) => {
    const tabs = container.querySelectorAll<HTMLButtonElement>(".install-tab");
    const panels = container.querySelectorAll<HTMLDivElement>(".install-panel");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const key = tab.dataset.tab;
        tabs.forEach((t) => {
          const active = t.dataset.tab === key;
          t.setAttribute("aria-selected", String(active));
          t.classList.toggle("border-primary", active);
          t.classList.toggle("text-primary", active);
          t.classList.toggle("dark:text-primary-light", active);
          t.classList.toggle("border-transparent", !active);
          t.classList.toggle("text-slate-500", !active);
        });
        panels.forEach((p) => {
          p.classList.toggle("hidden", p.dataset.panel !== key);
        });
      });
    });

    container.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const cmd = btn.dataset.command;
        if (cmd) {
          await navigator.clipboard.writeText(cmd);
          btn.innerHTML = `<svg class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" /></svg>`;
          setTimeout(() => {
            btn.innerHTML = `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" /></svg>`;
          }, 2000);
        }
      });
    });
  });
</script>
